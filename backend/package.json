{
  "name": "ecotrace-backend",
  "version": "1.0.0",
  "description": "Express backend for EcoTrace carbon footprint awareness platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "npx eslint src",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest --runInBand --detectOpenHandles",
    "test:coverage": "jest --coverage --runInBand --detectOpenHandles",
    "test:mutation": "stryker run",
    "test:perf": "artillery run tests/load/dashboard.yml",
    "test:visual": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^4.4.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/storage": "^7.11.0",
    "@google-cloud/vertexai": "^1.2.0",
    "cors": "^2.8.5",
    "csv-stringify": "^6.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^12.1.1",
    "helmet": "^7.1.0",
    "pdfkit": "^0.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/pdfkit": "^0.13.4",
    "@types/supertest": "^6.0.2",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
